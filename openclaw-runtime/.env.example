# Blender LLM API Configuration
# Optional: if not provided, local fallback fusion will be used
BLENDER_API_KEY=your_api_key_here
BLENDER_MODEL=gpt-4
BLENDER_BASE_URL=https://api.openai.com/v1

# Optional: show full fusion content in smoke test
SHOW_FULL_FUSION=false

# Browser automation video demo (Task 2)
OPENCLAW_SKILL_SERVICE_URL=http://127.0.0.1:8080
OPENCLAW_SKILL_SERVICE_API_KEY=your_openclaw_skill_key_here

# Generic provider switching (no code change needed)
VIDEO_BROWSER_PROVIDER=jimeng
VIDEO_BROWSER_START_URL=
# JSON array, supports placeholders: {{PROMPT}}, {{DURATION_SEC}}, {{RESOLUTION}}
# Example: ["wait:dom-ready","type:selector=textarea, value={{PROMPT}}","click:text=Generate","wait:text=Complete"]
VIDEO_BROWSER_ACTIONS_JSON=

# Provider preset: jimeng
JIMENG_WEB_URL=https://jimeng.jianying.com/ai-tool/home/?utm_medium=baiduads&utm_source=pinzhuan&utm_campaign=title

# Research agent: Baidu search + webpage summary demo
BAIDU_WEB_URL=https://www.baidu.com
BAIDU_SEARCH_KEYWORD=
BAIDU_TOP_K=5
# JSON array, supports placeholder: {{QUERY}}
# Example: ["wait:dom-ready","type:selector=input[name='wd'], value={{QUERY}}","click:selector=input[type='submit']","wait:dom-ready","extract:list=.result h3 a"]
BAIDU_BROWSER_ACTIONS_JSON=

# Feishu gateway (message -> runtime -> reply)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_GATEWAY_HOST=0.0.0.0
FEISHU_GATEWAY_PORT=9090
